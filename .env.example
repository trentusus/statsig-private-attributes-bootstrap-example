STATSIG_SERVER_KEY=secret-REPLACE_ME
STATSIG_CLIENT_KEY=client-REPLACE_ME
STATSIG_GATE_NAME=new_feature
PORT=3000

# Optional Node Core debugging
STATSIG_OUTPUT_LOG_LEVEL=debug
STATSIG_ENABLE_VERBOSE_LOGGER=false
STATSIG_INIT_TIMEOUT_MS=3000
STATSIG_FALLBACK_TO_STATSIG_API=false

# Optional custom endpoints
STATSIG_SPECS_URL=
STATSIG_LOG_EVENT_URL=
STATSIG_ID_LISTS_URL=

# Optional outbound proxy for Node Core
STATSIG_PROXY_PROTOCOL=
STATSIG_PROXY_HOST=
STATSIG_PROXY_PORT=
STATSIG_PROXY_AUTH=
STATSIG_PROXY_CA_CERT_PATH=
